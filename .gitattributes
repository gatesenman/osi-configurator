# 跨平台换行符统一：仓库内一律 LF，避免 Windows CRLF 导致的 diff 噪音与脚本失败
* text=auto eol=lf

# 源码与配置强制 LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Windows 批处理脚本保留 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不做任何转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
